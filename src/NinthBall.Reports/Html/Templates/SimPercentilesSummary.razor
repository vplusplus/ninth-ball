@using System;
@using NinthBall.Core;
@using NinthBall.Reports;

<!-- Summary view of chosen percentiles -->
<table id="percentiles" class="table table-sm caption-top section" style="table-layout: fixed; width: 100%;">
    <caption>
        <h3>Percentiles</h3>
    </caption>
    <tbody>

        @{
            var pctlSummary = Percentiles.Select(p => new
            {
                Caption = p.PctlName,
                Iter    = SimResult.IterationAtPercentile(p)
            })
            .Select(x => new
            {
                x.Caption,
                RealAnnualizedReturn    = $"{x.Iter.RealAnnualizedReturn:P1}",
                RealEndingBalance       = x.Iter.Success ? x.Iter.RealEndingBalance.Millions() : "--",
                AnnualizedReturn        = $"{x.Iter.AnnualizedReturn:P1}",
                EndingBalance           = x.Iter.Success ? x.Iter.EndingBalance.Millions() : "--",
            })
            .ToArray();
        }

        <!-- Percentile Tags -->
        <tr>
            <td>Percentile</td>

            @foreach (var p in pctlSummary)
            {
                <td class="text-primary">
                    @p.Caption
                </td>
            }
        </tr>

        <!-- Ending balance and CAGR (Real) -->
        <tr>
            <th>Ending Balance (r)</th>

            @foreach (var p in pctlSummary)
            {
                <th>@p.RealEndingBalance</th>
            }
        </tr>

        <tr>
            <th>CAGR (r)</th>

            @foreach (var p in pctlSummary)
            {
                <th>@p.RealAnnualizedReturn</th>
            }
        </tr>

        <!-- Ending balance and CAGR (Nominal) -->
        <tr>
            <td class="text-secondary">Ending Balance (n)</td>

            @foreach (var p in pctlSummary)
            {
                <td class="text-secondary">@p.EndingBalance</td>
            }
        </tr>
        <tr>
            <td class="text-secondary">CAGR (n)</td>

            @foreach (var p in pctlSummary)
            {
                <td class="text-secondary">@p.AnnualizedReturn</td>
            }
        </tr>

    </tbody>

</table>

@code
{
    [CascadingParameter]
    public SimResult SimResult { get; set; } = null!;
    
    [CascadingParameter(Name = "Columns")]
    public IReadOnlyList<CID> Columns { get; set; } = [];
    
    [CascadingParameter(Name = "Percentiles")]
    public IReadOnlyList<double> Percentiles { get; set; } = [];
    
    [CascadingParameter(Name = "Iterations")]
    public IReadOnlyList<int> Iterations { get; set; } = [];
}
